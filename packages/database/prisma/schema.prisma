generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationType {
  LOGISTICS_COMPANY
  CARGO_OWNER
  CUSTOMS_AGENT
  TRANSPORT_COMPANY
  YARD_OPERATOR
  OTHER
}

enum MembershipRole {
  OWNER
  ADMIN
  DISPATCHER
  DOCUMENT_STAFF
  FIELD_OPERATOR
  VIEWER
  BILLING_ADMIN
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum MembershipInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum VehicleType {
  TRUCK
  TRACTOR_HEAD
  TRAILER
  CONTAINER_TRUCK
  VAN
  OTHER
}

enum OwnershipType {
  OWNED
  LEASED
  PARTNER
  CUSTOMER
  OTHER
}

enum TripType {
  EXPORT_WITH_GOODS
  IMPORT_WITH_GOODS
  EMPTY_VEHICLE_ENTRY
  EMPTY_VEHICLE_EXIT
  YARD_ONLY
  INTERNAL_TRANSFER
}

enum TripDirection {
  EXPORT
  IMPORT
  DOMESTIC
  UNKNOWN
}

enum TripStatus {
  PLANNED
  IN_PROGRESS
  WAITING_YARD_ENTRY
  IN_YARD
  AT_BORDER_GATE
  CUSTOMS_PROCESSING
  INSPECTION_REQUIRED
  BLOCKED
  DELAYED
  COMPLETED
  CANCELLED
}

enum TripParticipantRole {
  OWNER_ORG
  DRIVER
  CARGO_OWNER
  CUSTOMS_AGENT
  FIELD_OPERATOR
  VIEWER
}

enum VisibilityLevel {
  FULL
  OPERATIONAL
  MILESTONE_ONLY
  LIMITED
}

enum TripEventType {
  TRIP_CREATED
  VEHICLE_ASSIGNED
  DRIVER_ASSIGNED
  DEPARTED
  ARRIVED_BORDER_AREA
  WAITING_YARD_ENTRY
  YARD_ENTRY_CONFIRMED
  DRIVER_REPORTED_YARD_ENTRY
  YARD_EXIT_CONFIRMED
  DRIVER_REPORTED_GATE_ENTRY
  DECLARATION_SUBMITTED
  DECLARATION_APPROVED
  DECLARATION_REJECTED
  BORDER_GATE_ENTRY_CONFIRMED
  CUSTOMS_PROCESSING
  INSPECTION_REQUIRED
  INSPECTION_COMPLETED
  FEE_PAID
  BORDER_GATE_EXIT_CONFIRMED
  TRANSSHIPMENT_ELIGIBLE
  TRANSSHIPMENT_SIGNED
  TRANSSHIPMENT_STARTED
  TRANSSHIPMENT_COMPLETED
  DRIVER_LOCATION_SHARED
  DRIVER_MEDIA_UPLOADED
  RELEASE_READY
  RELEASE_REQUESTED
  VEHICLE_RELEASED
  PROOF_IMAGE_UPLOADED
  DRIVER_NOTE_ADDED
  TRIP_CANCELLED
  TRIP_COMPLETED
}

enum TripEventStatus {
  RECORDED
  CONFIRMED
  REJECTED
  CORRECTED
  CONFLICTING
}

enum TripEventSource {
  MANUAL
  DRIVER_APP
  IMPORT
  CUA_KHAU_SO
  XUAN_CUONG
  GPS
  SYSTEM
  AI_ASSISTANT
}

enum IntegrationProvider {
  CUA_KHAU_SO
  XUAN_CUONG
  GPS_PROVIDER
  ZALO_OA
  EMAIL
  SMS
  MOCK
}

enum IntegrationStatus {
  ACTIVE
  DISABLED
  ERROR
  PENDING
}

enum NotificationChannel {
  EMAIL
  IN_APP
  WEB_PUSH
  ZALO_OA
  SMS
  WEBHOOK
}

enum IntegrationSyncRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

enum TripMediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum DeclarationType {
  EXPORT
  IMPORT
  TRANSIT
  OTHER
}

enum DeclarationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

model Organization {
  id                   String               @id @default(uuid()) @db.Uuid
  name                 String
  type                 OrganizationType     @default(LOGISTICS_COMPANY)
  taxCode              String?
  phone                String?
  email                String?
  address              String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  deletedById          String?              @db.Uuid
  memberships          Membership[]
  membershipInvitations MembershipInvitation[]
  driverProfiles       DriverProfile[]
  vehicles             Vehicle[]
  shipments            Shipment[]           @relation("OwningOrganizationShipments")
  cargoOwnerShipments  Shipment[]           @relation("CargoOwnerShipments")
  customsDeclarations  CustomsDeclaration[]
  trips                Trip[]
  tripParticipants     TripParticipant[]
  tripEvents           TripEvent[]
  integrationAccounts  IntegrationAccount[]
  integrationSyncRuns  IntegrationSyncRun[]
  notificationRules    NotificationRule[]
  notifications        Notification[]
  tripMediaAttachments TripMediaAttachment[]
  auditLogs            AuditLog[]

  @@index([type])
  @@index([taxCode])
  @@map("organizations")
}

model User {
  id                 String            @id @default(uuid()) @db.Uuid
  supabaseUserId     String            @unique
  fullName           String?
  phone              String?
  email              String?           @unique
  avatarUrl          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  memberships        Membership[]
  createdMembershipInvitations MembershipInvitation[] @relation("MembershipInvitationCreatedBy")
  acceptedMembershipInvitations MembershipInvitation[] @relation("MembershipInvitationAcceptedBy")
  revokedMembershipInvitations  MembershipInvitation[] @relation("MembershipInvitationRevokedBy")
  driverProfile      DriverProfile?
  createdTrips       Trip[]            @relation("TripCreatedBy")
  tripParticipants   TripParticipant[]
  tripEvents         TripEvent[]       @relation("TripEventCreatedBy")
  uploadedTripMediaAttachments TripMediaAttachment[] @relation("TripMediaAttachmentUploadedBy")
  notifications      Notification[]
  auditLogs          AuditLog[]

  @@index([supabaseUserId])
  @@index([phone])
  @@map("users")
}

model Membership {
  id              String             @id @default(uuid()) @db.Uuid
  organizationId  String             @db.Uuid
  userId          String             @db.Uuid
  role            MembershipRole
  status          MembershipStatus   @default(ACTIVE)
  createdAt       DateTime           @default(now())
  deletedAt       DateTime?
  deletedById     String?            @db.Uuid
  organization    Organization       @relation(fields: [organizationId], references: [id])
  user            User               @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId, organizationId])
  @@index([organizationId, role, status])
  @@map("memberships")
}

model MembershipInvitation {
  id              String                     @id @default(uuid()) @db.Uuid
  organizationId  String                     @db.Uuid
  email           String
  role            MembershipRole
  codeHash        String                     @unique
  status          MembershipInvitationStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  acceptedById    String?                    @db.Uuid
  revokedAt       DateTime?
  revokedById     String?                    @db.Uuid
  createdById     String?                    @db.Uuid
  createdAt       DateTime                   @default(now())
  organization    Organization               @relation(fields: [organizationId], references: [id])
  acceptedBy      User?                      @relation("MembershipInvitationAcceptedBy", fields: [acceptedById], references: [id])
  revokedBy       User?                      @relation("MembershipInvitationRevokedBy", fields: [revokedById], references: [id])
  createdBy       User?                      @relation("MembershipInvitationCreatedBy", fields: [createdById], references: [id])

  @@index([organizationId, status, expiresAt])
  @@index([email, status])
  @@map("membership_invitations")
}

model DriverProfile {
  id                 String     @id @default(uuid()) @db.Uuid
  organizationId     String     @db.Uuid
  userId             String?    @unique @db.Uuid
  displayName        String?
  licenseNumber      String?
  phone              String?
  identityVerifiedAt DateTime?
  createdAt          DateTime   @default(now())
  deletedAt          DateTime?
  deletedById        String?    @db.Uuid
  organization       Organization @relation(fields: [organizationId], references: [id])
  user               User?      @relation(fields: [userId], references: [id])
  vehicles           Vehicle[]
  trips              Trip[]

  @@index([organizationId])
  @@index([phone])
  @@index([licenseNumber])
  @@map("driver_profiles")
}

model Vehicle {
  id                String          @id @default(uuid()) @db.Uuid
  organizationId    String          @db.Uuid
  plateNumber       String
  vehicleType       VehicleType
  ownershipType     OwnershipType   @default(OWNED)
  defaultDriverId   String?         @db.Uuid
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  deletedById       String?         @db.Uuid
  organization      Organization    @relation(fields: [organizationId], references: [id])
  defaultDriver     DriverProfile?  @relation(fields: [defaultDriverId], references: [id])
  trips             Trip[]

  @@unique([organizationId, plateNumber])
  @@index([organizationId, vehicleType])
  @@map("vehicles")
}

model BorderGate {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  province     String?
  countrySide  String?
  isActive     Boolean  @default(true)
  yards        Yard[]
  trips        Trip[]

  @@index([isActive])
  @@map("border_gates")
}

model Yard {
  id            String      @id @default(uuid()) @db.Uuid
  name          String
  borderGateId  String      @db.Uuid
  operatorName  String?
  address       String?
  isActive      Boolean     @default(true)
  borderGate    BorderGate  @relation(fields: [borderGateId], references: [id])
  trips         Trip[]

  @@unique([borderGateId, name])
  @@index([borderGateId, isActive])
  @@map("yards")
}

model Shipment {
  id                         String        @id @default(uuid()) @db.Uuid
  organizationId             String        @db.Uuid
  cargoOwnerOrganizationId   String?       @db.Uuid
  description                String?
  commodityCode              String?
  quantity                   Decimal?      @db.Decimal(18, 3)
  unit                       String?
  weightKg                   Decimal?      @db.Decimal(18, 3)
  containerNumber            String?
  sealNumber                 String?
  createdAt                  DateTime      @default(now())
  organization               Organization  @relation("OwningOrganizationShipments", fields: [organizationId], references: [id])
  cargoOwnerOrganization     Organization? @relation("CargoOwnerShipments", fields: [cargoOwnerOrganizationId], references: [id])
  trips                      Trip[]

  @@index([organizationId])
  @@index([cargoOwnerOrganizationId])
  @@index([containerNumber])
  @@map("shipments")
}

model CustomsDeclaration {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @db.Uuid
  declarationNumber    String
  declarationType      DeclarationType
  customsOfficeCode    String?
  status               DeclarationStatus  @default(DRAFT)
  submittedAt          DateTime?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  createdAt            DateTime           @default(now())
  organization         Organization       @relation(fields: [organizationId], references: [id])
  trips                Trip[]

  @@unique([organizationId, declarationNumber])
  @@index([organizationId, status])
  @@map("customs_declarations")
}

model Trip {
  id                       String               @id @default(uuid()) @db.Uuid
  organizationId           String               @db.Uuid
  tripCode                 String
  tripType                 TripType
  direction                TripDirection        @default(UNKNOWN)
  vehicleId                String?              @db.Uuid
  driverProfileId          String?              @db.Uuid
  shipmentId               String?              @db.Uuid
  customsDeclarationId     String?              @db.Uuid
  borderGateId             String?              @db.Uuid
  yardId                   String?              @db.Uuid
  plannedStartAt           DateTime?
  plannedArrivalAt         DateTime?
  currentStatus            TripStatus           @default(PLANNED)
  currentStatusUpdatedAt   DateTime?
  createdById              String?              @db.Uuid
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  deletedAt                DateTime?
  deletedById              String?              @db.Uuid
  organization             Organization         @relation(fields: [organizationId], references: [id])
  vehicle                  Vehicle?             @relation(fields: [vehicleId], references: [id])
  driverProfile            DriverProfile?       @relation(fields: [driverProfileId], references: [id])
  shipment                 Shipment?            @relation(fields: [shipmentId], references: [id])
  customsDeclaration       CustomsDeclaration?  @relation(fields: [customsDeclarationId], references: [id])
  borderGate               BorderGate?          @relation(fields: [borderGateId], references: [id])
  yard                     Yard?                @relation(fields: [yardId], references: [id])
  createdBy                User?                @relation("TripCreatedBy", fields: [createdById], references: [id])
  participants             TripParticipant[]
  events                   TripEvent[]
  mediaAttachments         TripMediaAttachment[]
  notifications            Notification[]

  @@unique([organizationId, tripCode])
  @@index([organizationId, currentStatus, plannedStartAt])
  @@index([driverProfileId, currentStatus])
  @@index([vehicleId, currentStatus])
  @@map("trips")
}

model TripParticipant {
  id               String               @id @default(uuid()) @db.Uuid
  tripId           String               @db.Uuid
  organizationId   String?              @db.Uuid
  userId           String?              @db.Uuid
  role             TripParticipantRole
  visibilityLevel  VisibilityLevel      @default(OPERATIONAL)
  createdAt        DateTime             @default(now())
  trip             Trip                 @relation(fields: [tripId], references: [id])
  organization     Organization?        @relation(fields: [organizationId], references: [id])
  user             User?                @relation(fields: [userId], references: [id])

  @@index([tripId, role])
  @@index([organizationId])
  @@index([userId])
  @@map("trip_participants")
}

model TripEvent {
  id              String            @id @default(uuid()) @db.Uuid
  tripId          String            @db.Uuid
  organizationId  String            @db.Uuid
  eventType       TripEventType
  eventStatus     TripEventStatus   @default(RECORDED)
  source          TripEventSource
  sourceRef       String?
  idempotencyKey  String?
  occurredAt      DateTime
  recordedAt      DateTime          @default(now())
  createdById     String?           @db.Uuid
  confidence      Decimal?          @db.Decimal(5, 2)
  note            String?
  rawPayload      Json?
  trip            Trip              @relation(fields: [tripId], references: [id])
  organization    Organization      @relation(fields: [organizationId], references: [id])
  createdBy       User?             @relation("TripEventCreatedBy", fields: [createdById], references: [id])
  mediaAttachments TripMediaAttachment[]

  @@unique([idempotencyKey])
  @@index([tripId, occurredAt])
  @@index([organizationId, eventType, occurredAt])
  @@index([source, sourceRef])
  @@map("trip_events")
}

model IntegrationAccount {
  id                    String                @id @default(uuid()) @db.Uuid
  organizationId        String                @db.Uuid
  provider              IntegrationProvider
  displayName           String
  status                IntegrationStatus     @default(PENDING)
  encryptedCredentials  String?
  lastSyncAt            DateTime?
  createdAt             DateTime              @default(now())
  deletedAt             DateTime?
  deletedById           String?               @db.Uuid
  organization          Organization          @relation(fields: [organizationId], references: [id])
  syncRuns              IntegrationSyncRun[]

  @@unique([organizationId, provider, displayName])
  @@index([organizationId, provider])
  @@map("integration_accounts")
}

model IntegrationSyncRun {
  id                   String                   @id @default(uuid()) @db.Uuid
  organizationId       String                   @db.Uuid
  integrationAccountId String                   @db.Uuid
  status               IntegrationSyncRunStatus @default(RUNNING)
  mode                 String                   @default("AUTO")
  startedAt            DateTime                 @default(now())
  finishedAt           DateTime?
  recordsFetched       Int                      @default(0)
  detailsFetched       Int                      @default(0)
  eventsCreated        Int                      @default(0)
  eventsSkipped        Int                      @default(0)
  errorMessage         String?
  metadata             Json?
  organization         Organization             @relation(fields: [organizationId], references: [id])
  integrationAccount   IntegrationAccount       @relation(fields: [integrationAccountId], references: [id])

  @@index([organizationId, startedAt])
  @@index([integrationAccountId, startedAt])
  @@index([status, startedAt])
  @@map("integration_sync_runs")
}

model TripMediaAttachment {
  id              String         @id @default(uuid()) @db.Uuid
  organizationId  String         @db.Uuid
  tripId          String         @db.Uuid
  tripEventId     String?        @db.Uuid
  uploadedById    String?        @db.Uuid
  mediaType       TripMediaType
  fileName        String
  mimeType        String?
  storagePath     String?
  publicUrl       String?
  sizeBytes       Int?
  message         String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  organization    Organization   @relation(fields: [organizationId], references: [id])
  trip            Trip           @relation(fields: [tripId], references: [id])
  tripEvent       TripEvent?     @relation(fields: [tripEventId], references: [id])
  uploadedBy      User?          @relation("TripMediaAttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([organizationId, createdAt])
  @@index([tripId, createdAt])
  @@index([tripEventId])
  @@index([uploadedById])
  @@map("trip_media_attachments")
}

model NotificationRule {
  id                  String                 @id @default(uuid()) @db.Uuid
  organizationId      String                 @db.Uuid
  name                String
  eventType           TripEventType?
  condition           Json?
  channels            NotificationChannel[]
  recipientStrategy   Json?
  isActive            Boolean                @default(true)
  organization        Organization           @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isActive])
  @@map("notification_rules")
}

model Notification {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @db.Uuid
  tripId            String?              @db.Uuid
  recipientUserId   String?              @db.Uuid
  channel           NotificationChannel
  status            NotificationStatus   @default(PENDING)
  payload           Json?
  sentAt            DateTime?
  failedAt          DateTime?
  readAt            DateTime?
  errorMessage      String?
  createdAt         DateTime             @default(now())
  organization      Organization         @relation(fields: [organizationId], references: [id])
  trip              Trip?                @relation(fields: [tripId], references: [id])
  recipientUser     User?                @relation(fields: [recipientUserId], references: [id])

  @@index([recipientUserId, status, createdAt])
  @@index([organizationId, status])
  @@map("notifications")
}

model AuditLog {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String?       @db.Uuid
  actorUserId     String?       @db.Uuid
  action          String
  entityType      String
  entityId        String?
  before          Json?
  after           Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())
  organization    Organization? @relation(fields: [organizationId], references: [id])
  actorUser       User?         @relation(fields: [actorUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
