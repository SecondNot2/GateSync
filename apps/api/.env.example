DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
ENCRYPTION_KEY=

# ─── Redis / BullMQ ────────────────────────────────────────────────────────
# Shared Redis connection used by the AUTO SYNC pipeline (Sync_Worker) and
# the External Channel Dispatcher (Zalo / SMS / Email). When unset, both
# workers log a warning and stay inert; sync runs queued by the scheduler
# remain in `QUEUED` state and external `Notification` rows remain
# `PENDING` until a process with REDIS_URL drains them. This is the
# documented in-memory / no-op fallback for local development (task 17.2,
# Requirements 13.1, 13.2, 13.3).
REDIS_URL=

# ─── Sync worker (apps/api `integrations` module) ──────────────────────────
# Per-provider RPS limits applied via BullMQ `limiter: { max, duration: 1000 }`.
# Variable name uses the Prisma `IntegrationProvider` enum value verbatim:
# `SYNC_WORKER_<PROVIDER>_RPS`. Falls back to `SYNC_WORKER_DEFAULT_RPS`
# (default 10) when the provider-specific value is unset.
# Queue names: `sync-run:cks`, `sync-run:yard`, `sync-run:gps`, `sync-run:mock`.
SYNC_WORKER_CONCURRENCY=2
SYNC_WORKER_DEFAULT_RPS=10
SYNC_WORKER_CUA_KHAU_SO_RPS=
SYNC_WORKER_XUAN_CUONG_RPS=
SYNC_WORKER_GPS_PROVIDER_RPS=
SYNC_WORKER_MOCK_RPS=

# Backpressure watermarks observed by `Sync_Scheduler`. When the total
# queued+running run count crosses HIGH the scheduler skips new ticks; it
# resumes once the count falls below LOW (Requirement 13.2).
SYNC_QUEUE_HIGH_WATERMARK=200
SYNC_QUEUE_LOW_WATERMARK=100

# ─── Notification dispatcher (apps/api `notifications/external`) ───────────
# Per-channel concurrency for the `notification-external-zalo`,
# `notification-external-sms`, `notification-external-email` queues.
NOTIFICATIONS_DISPATCHER_CONCURRENCY=4

# ─── Misc ──────────────────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
CUA_KHAU_SO_BASE_URL=https://cuakhauso.langson.gov.vn
CUA_KHAU_SO_POLLING_ENABLED=false
CUA_KHAU_SO_POLLING_INTERVAL_MS=60000
CUA_KHAU_SO_REFRESH_THROTTLE_MS=60000
CUA_KHAU_SO_STALE_AFTER_MS=1800000
